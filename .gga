# GGA Configuration for Route Flow

# AI Provider (claude, gemini, ollama, opencode, etc.)
PROVIDER=ollama:llama3

# Ollama must be running: ollama serve
# Or use other providers:
# PROVIDER=claude
# PROVIDER=gemini
# PROVIDER=opencode

# Cache settings
CACHE_ENABLED=true
CACHE_DIR=.gga-cache

# Timeout in seconds
TIMEOUT=30

# Max files to review per run
MAX_FILES=10

# Enable verbose output
VERBOSE=false
