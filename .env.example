# ============================================
# Route Flow - Environment Variables
# ============================================

# --------------------------------------------
# REQUIRED - Google Maps API Key
# --------------------------------------------
# Get free key at: https://console.cloud.google.com/google/maps-apis/
# Enable: Directions API, Distance Matrix API, Geocoding API, Maps JavaScript API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# For client-side usage (optional - only if needed)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# --------------------------------------------
# OPTIONAL - OpenRouteService (Fallback)
# --------------------------------------------
# Get free key at: https://openrouteservice.org/dev/#/signup
# Only needed if Google Maps is unavailable
# NEXT_PUBLIC_ORS_API_KEY=your-ors-api-key-here
